DEBUG=False
ENABLE_API_DOCS=False
SECRET_KEY=GERAR_CHAVE_FORTE_UNICA_PARA_A_DEMO

# Demo publica RH SaaS
ALLOWED_HOSTS=api-demo-rh.taquiondev.com.br,.api-demo-rh.taquiondev.com.br
CSRF_TRUSTED_ORIGINS=https://demo-rh.taquiondev.com.br,https://api-demo-rh.taquiondev.com.br,https://*.api-demo-rh.taquiondev.com.br
CORS_ALLOWED_ORIGINS=https://demo-rh.taquiondev.com.br
CORS_ALLOW_CREDENTIALS=True
NEXT_FRONTEND_URL=https://demo-rh.taquiondev.com.br
NEXT_FRONTEND_LEGACY_REDIRECTS_ENABLED=False
NEXT_FRONTEND_LEGACY_REDIRECT_SURFACES=

DATABASE_URL=postgres://rhsaas:SENHA_FORTE_DO_BANCO@localhost:5432/rhsaas
DB_CONN_MAX_AGE=60
DB_CONN_HEALTH_CHECKS=True

CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
CACHE_LOCATION=redis://127.0.0.1:6379/1
CACHE_KEY_PREFIX=rhsaas_demo

DRF_THROTTLE_ANON_RATE=60/minute
DRF_THROTTLE_USER_RATE=300/minute
DRF_THROTTLE_AUTH_LOGIN_RATE=10/minute
DRF_THROTTLE_DEMO_LEASE_RATE=3/hour
DRF_THROTTLE_DEMO_EXCHANGE_RATE=10/hour
DRF_THROTTLE_BACKUP_CREATE_RATE=1/hour
DRF_THROTTLE_BACKUP_DOWNLOAD_RATE=5/minute
DRF_THROTTLE_EXPORT_CSV_RATE=3/minute
DATA_UPLOAD_MAX_MEMORY_SIZE=1048576
FILE_UPLOAD_MAX_MEMORY_SIZE=1048576

# Manter False durante deploy/migrations/provisionamento. Ativar somente depois
# de validar demo1...demo10, timer, health check e smoke test ponta a ponta.
DEMO_PUBLIC_LEASE_ENABLED=False
DEMO_PUBLIC_ENTRY_SCHEMA=rh_teste
DEMO_LEASE_DURATION_MINUTES=60
DEMO_EXCHANGE_TOKEN_TTL_SECONDS=300
DEMO_VISITOR_COOKIE_MAX_AGE=86400

SESSION_ENGINE=django.contrib.sessions.backends.db
SESSION_COOKIE_AGE=1800
SESSION_EXPIRE_AT_BROWSER_CLOSE=True
SESSION_SAVE_EVERY_REQUEST=False
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_DOMAIN=

CSRF_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SECURE=True
CSRF_COOKIE_DOMAIN=

SECURE_SSL_REDIRECT=True
SECURE_PROXY_SSL_HEADER=True
# HSTS inicial conservador para a primeira publicacao.
# Aumentar para 31536000 apenas depois de validar HTTPS, DNS, cookies e redirects.
SECURE_HSTS_SECONDS=300
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

WHITENOISE_MAX_AGE=31536000
CSP_UPGRADE_INSECURE_REQUESTS=True
CSP_EXCLUDED_PATH_PREFIXES=/admin/
PERMISSIONS_POLICY=geolocation=(), microphone=(), camera=()
CROSS_ORIGIN_OPENER_POLICY=same-origin
CROSS_ORIGIN_RESOURCE_POLICY=same-origin
X_PERMITTED_CROSS_DOMAIN_POLICIES=none

PASSWORD_RESET_TIMEOUT=3600
PASSWORD_RESET_RATE_LIMIT_ATTEMPTS=5
PASSWORD_RESET_RATE_LIMIT_WINDOW=3600
PASSWORD_RESET_TRUST_X_FORWARDED_FOR=False

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=RH SaaS Demo <nao-responder@taquiondev.com.br>
RESEND_API_KEY=

LOG_LEVEL=INFO
