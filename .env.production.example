DEBUG=False
SECRET_KEY=gere-uma-chave-grande-e-unica
ALLOWED_HOSTS=.rhsaas.example.com,rhsaas.example.com,IP_DO_SERVIDOR
CSRF_TRUSTED_ORIGINS=https://*.rhsaas.example.com,https://rhsaas.example.com,https://app.rhsaas.example.com
CORS_ALLOWED_ORIGINS=https://app.rhsaas.example.com
CORS_ALLOW_CREDENTIALS=True
NEXT_FRONTEND_URL=https://app.rhsaas.example.com
NEXT_FRONTEND_LEGACY_REDIRECTS_ENABLED=False
NEXT_FRONTEND_LEGACY_REDIRECT_SURFACES=
DATABASE_URL=postgres://rhsaas:SENHA_FORTE@localhost:5432/rhsaas
DB_CONN_MAX_AGE=60
DB_CONN_HEALTH_CHECKS=True
# Redis compartilha cache entre workers/processos do Gunicorn.
CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
CACHE_LOCATION=redis://127.0.0.1:6379/1
CACHE_KEY_PREFIX=rhsaas
DRF_THROTTLE_ANON_RATE=120/minute
DRF_THROTTLE_USER_RATE=1200/minute
DRF_THROTTLE_AUTH_LOGIN_RATE=20/minute

SESSION_ENGINE=django.contrib.sessions.backends.db
SESSION_COOKIE_AGE=1800
SESSION_EXPIRE_AT_BROWSER_CLOSE=True
SESSION_SAVE_EVERY_REQUEST=False
# Em multi-tenant por subdominio, manter dominios de cookie vazios para cookies host-only.
# Nao use Domain=.rhsaas.example.com para sessao/CSRF: cada tenant deve ter cookie proprio por Host.
# Em demo publica/HTTPS, COOKIE_SECURE deve permanecer True.
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_DOMAIN=
CSRF_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SECURE=True
CSRF_COOKIE_DOMAIN=
SECURE_SSL_REDIRECT=True
SECURE_PROXY_SSL_HEADER=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
WHITENOISE_MAX_AGE=31536000
CSP_UPGRADE_INSECURE_REQUESTS=True
CSP_EXCLUDED_PATH_PREFIXES=/admin/
PERMISSIONS_POLICY=geolocation=(), microphone=(), camera=()
CROSS_ORIGIN_OPENER_POLICY=same-origin
CROSS_ORIGIN_RESOURCE_POLICY=same-origin
X_PERMITTED_CROSS_DOMAIN_POLICIES=none

PASSWORD_RESET_TIMEOUT=3600
PASSWORD_RESET_RATE_LIMIT_ATTEMPTS=5
PASSWORD_RESET_RATE_LIMIT_WINDOW=3600
PASSWORD_RESET_TRUST_X_FORWARDED_FOR=False

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=RH SaaS <nao-responder@rhsaas.example.com>
RESEND_API_KEY=
LOG_LEVEL=INFO
