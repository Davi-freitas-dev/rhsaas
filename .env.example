# Demo local: use apenas valores booleanos claros (True/False).
# Se existir uma variavel DEBUG do sistema com outro valor, como "release",
# remova-a ou sobrescreva no terminal antes de rodar manage.py.
DEBUG=True
# Demo local: gere uma chave longa e unica. Nunca use este placeholder em ambiente exposto.
# Exemplo para gerar: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=gere-uma-chave-local-grande-e-unica
ALLOWED_HOSTS=.localhost,localhost,127.0.0.1,rh-teste.localhost
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000,http://rh-teste.localhost,http://rh-teste.localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://rh-teste.localhost:3000
CORS_ALLOW_CREDENTIALS=True
NEXT_FRONTEND_URL=http://localhost:3000
NEXT_FRONTEND_LEGACY_REDIRECTS_ENABLED=False
NEXT_FRONTEND_LEGACY_REDIRECT_SURFACES=
# django-tenants requer PostgreSQL; SQLite nao e suportado neste spike.
DATABASE_URL=postgres://postgres:SENHA_LOCAL@localhost:5433/rhsaas_dev
DB_CONN_MAX_AGE=0
DB_CONN_HEALTH_CHECKS=False
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
CACHE_LOCATION=rhsaas-dev
CACHE_KEY_PREFIX=rhsaas-dev
DRF_THROTTLE_ANON_RATE=120/minute
DRF_THROTTLE_USER_RATE=1200/minute
DRF_THROTTLE_AUTH_LOGIN_RATE=20/minute
DRF_THROTTLE_DEMO_LEASE_RATE=100000/day
DRF_THROTTLE_DEMO_LEASE_RESUME_RATE=100000/day
DRF_THROTTLE_DEMO_EXCHANGE_RATE=100000/day
DRF_THROTTLE_DEMO_STATUS_RATE=100000/day
DRF_THROTTLE_BACKUP_CREATE_RATE=3/hour
DRF_THROTTLE_BACKUP_DOWNLOAD_RATE=30/minute
DRF_THROTTLE_EXPORT_CSV_RATE=10/minute

# Entrada automatica desligada por padrao, inclusive no desenvolvimento.
DEMO_PUBLIC_LEASE_ENABLED=False
DEMO_PERMANENT_TENANT_SCHEMA=demo1
DEMO_PUBLIC_POOL_SLOTS=demo2,demo3,demo4,demo5,demo6,demo7,demo8,demo9,demo10
DEMO_PUBLIC_ENTRY_SCHEMA=rh_teste
DEMO_LEASE_DURATION_MINUTES=60
DEMO_EXCHANGE_TOKEN_TTL_SECONDS=300
DEMO_VISITOR_COOKIE_MAX_AGE=86400
DEMO_MAX_ACTIVE_LEASES_PER_NETWORK=2

SESSION_ENGINE=django.contrib.sessions.backends.db
SESSION_COOKIE_AGE=1800
SESSION_EXPIRE_AT_BROWSER_CLOSE=True
SESSION_SAVE_EVERY_REQUEST=True
# Cookies host-only: mantenha SESSION_COOKIE_DOMAIN e CSRF_COOKIE_DOMAIN vazios.
# COOKIE_SECURE=False e apenas para demo local em HTTP. Em HTTPS publico, use True.
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_DOMAIN=
CSRF_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SECURE=False
CSRF_COOKIE_DOMAIN=
SECURE_SSL_REDIRECT=False
SECURE_PROXY_SSL_HEADER=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
WHITENOISE_MAX_AGE=0
CSP_UPGRADE_INSECURE_REQUESTS=False
CSP_EXCLUDED_PATH_PREFIXES=/admin/

PASSWORD_RESET_TIMEOUT=3600
PASSWORD_RESET_RATE_LIMIT_ATTEMPTS=5
PASSWORD_RESET_RATE_LIMIT_WINDOW=3600
PASSWORD_RESET_TRUST_X_FORWARDED_FOR=False

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=RH SaaS <nao-responder@seudominio.com>
RESEND_API_KEY=
LOG_LEVEL=INFO
